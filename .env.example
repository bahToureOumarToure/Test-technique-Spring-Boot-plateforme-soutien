# ============================================================
#  MODÈLE de configuration des secrets.
#  Copiez ce fichier en ".env" puis remplacez les valeurs.
#    Linux/Mac : cp .env.example .env
#    Windows   : copy .env.example .env
#  Le fichier ".env" réel est ignoré par git (voir .gitignore)
#  et ne doit JAMAIS être commité.
# ============================================================

# --- Base de données PostgreSQL ---
POSTGRES_DB=soutien_db
POSTGRES_USER=soutien
POSTGRES_PASSWORD=changez-moi-mot-de-passe-bdd

# --- Sécurité JWT ---
# Doit faire au moins 32 caractères (algorithme HS256).
APP_JWT_SECRET=changez-moi-cle-secrete-jwt-tres-longue-au-moins-32-caracteres
# Durée de validité d'un token en millisecondes (24h par défaut)
APP_JWT_EXPIRATION_MS=86400000
